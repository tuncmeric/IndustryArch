# Block direct access to library / config files in the api/ folder.
# Endpoint files (login.php, list.php, etc.) remain reachable.

<FilesMatch "(^config\.php|^config\.example\.php)$">
    Require all denied
</FilesMatch>

# Deny everything in the _lib/ subfolder.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^_lib/ - [F,L]
</IfModule>
