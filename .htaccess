# IndustryArch — cPanel deployment .htaccess
# Place at the document root (typically public_html) of your domain.

# ----------------------------------------------------------------------
# Default character set
# ----------------------------------------------------------------------
AddDefaultCharset UTF-8

# ----------------------------------------------------------------------
# SPA fallback — serve index.html for unknown paths
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Don't rewrite real files or directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Don't rewrite anything under /api or /uploads — let PHP/static serve them.
    RewriteRule ^api/ - [L]
    RewriteRule ^uploads/ - [L]

    # Everything else goes through index.html (React Router takes over).
    RewriteRule ^ index.html [L]
</IfModule>

# ----------------------------------------------------------------------
# Force HTTPS (uncomment after the SSL cert is in place)
# ----------------------------------------------------------------------
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} !=on
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ----------------------------------------------------------------------
# Security headers
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ----------------------------------------------------------------------
# Block dotfiles (e.g. .env if you ever drop one in by accident)
# ----------------------------------------------------------------------
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block access to PHP config and library files (only entry-point endpoints should be reachable)
<FilesMatch "(^config\.php|^config\.example\.php)$">
    Require all denied
</FilesMatch>

# ----------------------------------------------------------------------
# Caching for static assets
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg          "access plus 1 year"
    ExpiresByType image/png           "access plus 1 year"
    ExpiresByType image/webp          "access plus 1 year"
    ExpiresByType image/svg+xml       "access plus 1 year"
    ExpiresByType image/gif           "access plus 1 year"
    ExpiresByType text/css            "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff2          "access plus 1 year"
    ExpiresByType text/html           "access plus 0 seconds"
</IfModule>

# Don't cache the SPA shell — JS/CSS bundles are content-hashed so they cache for a year.
<Files "index.html">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </IfModule>
</Files>

# ----------------------------------------------------------------------
# Compression
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml font/woff2
</IfModule>
